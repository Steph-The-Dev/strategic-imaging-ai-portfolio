<section class="py-24 bg-surface-container-low dark:bg-slate-950 transition-colors duration-300" id="case-studies">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16 border-l-8 border-primary dark:border-primary-fixed pl-8 transition-colors">
      <span class="font-mono text-xs md:text-sm text-primary dark:text-primary-fixed font-bold uppercase tracking-[0.4em] mb-3 block">TEST_REPORT_084</span>
      <h2 class="font-mono font-extrabold text-3xl md:text-5xl text-on-background dark:text-slate-100 uppercase tracking-tighter transition-colors">Stain Normalization</h2>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 border border-outline-variant dark:border-slate-800 bg-white dark:bg-slate-900 shadow-xl transition-colors">
      <div class="lg:col-span-5 p-8 border-r border-outline-variant dark:border-slate-800 space-y-8 transition-colors">
        <div class="flex flex-wrap gap-2">
          <span class="font-mono text-[11px] md:text-xs bg-on-background dark:bg-slate-100 text-white dark:text-slate-900 px-2.5 py-1.5 uppercase">PyTorch_v2</span>
          <span class="font-mono text-[11px] md:text-xs bg-on-background dark:bg-slate-100 text-white dark:text-slate-900 px-2.5 py-1.5 uppercase">CycleGAN_Core</span>
          <span class="font-mono text-[11px] md:text-xs bg-on-background dark:bg-slate-100 text-white dark:text-slate-900 px-2.5 py-1.5 uppercase">CV_Engine</span>
        </div>
        
        <div class="space-y-4">
          <p class="font-mono text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed transition-colors">
            Investigation of domain shift mitigation in clinical histology. Translating color grading principles into generative adversarial architectures.
          </p>
        </div>
        
        <div class="grid grid-cols-2 gap-px bg-outline-variant dark:bg-slate-800 border border-outline-variant dark:border-slate-800 transition-colors">
          <div class="bg-surface dark:bg-slate-900 p-4 transition-colors">
            <div class="font-mono text-2xl font-bold text-primary dark:text-primary-fixed">87%</div>
            <div class="font-mono text-[10px] md:text-xs uppercase font-bold text-outline dark:text-slate-500">Shift_Reduction</div>
          </div>
          <div class="bg-surface dark:bg-slate-900 p-4 transition-colors">
            <div class="font-mono text-2xl font-bold text-primary dark:text-primary-fixed">+14%</div>
            <div class="font-mono text-[10px] md:text-xs uppercase font-bold text-outline dark:text-slate-500">Acc_Delta</div>
          </div>
        </div>
        
        <div class="bg-[#1e1e1e] dark:bg-black p-5 overflow-hidden border border-on-surface dark:border-slate-700 transition-colors">
          <div class="flex justify-between mb-4 border-b border-white/10 pb-3">
            <span class="font-mono text-[11px] md:text-xs text-gray-500 uppercase">File: normalization.py</span>
            <div class="flex space-x-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500/40"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/40"></div>
            </div>
          </div>
          <pre class="font-mono text-xs md:text-sm font-semibold text-blue-300 overflow-x-auto leading-relaxed"><code>def lab_norm(img):
  l, a, b = rgb2lab(img)
  norm_l = model_G(l)
  return lab2rgb(norm_l, a, b)</code></pre>
        </div>
      </div>
      
      <div class="lg:col-span-7 p-4 bg-on-background dark:bg-slate-950 relative flex items-center justify-center overflow-hidden transition-colors">
        <div class="absolute inset-0 opacity-10 technical-grid pointer-events-none"></div>
        <div class="relative w-full max-w-2xl aspect-[4/3] border border-white/20">
          <img alt="Microscopic histology slide" class="w-full h-full object-cover" src="/stain_visualization.png"/>
          <div class="absolute inset-0 flex items-center">
            <div class="w-1/2 h-full border-r border-white/50 backdrop-contrast-125 backdrop-saturate-150"></div>
          </div>
          <div class="absolute bottom-4 left-4 bg-black/80 px-3 py-1.5">
            <span class="font-mono text-[10px] md:text-xs text-white tracking-widest uppercase">Input: RAW_DATA</span>
          </div>
          <div class="absolute bottom-4 right-4 bg-primary px-3 py-1.5">
            <span class="font-mono text-[10px] md:text-xs text-white tracking-widest uppercase">Output: NORM_SIG</span>
          </div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 border border-white/50 flex items-center justify-center bg-white/10 backdrop-blur-sm">
            <span class="material-symbols-outlined text-white text-sm">compare_arrows</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
