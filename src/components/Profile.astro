---
import { Image } from 'astro:assets';
import operatorProfile from '../assets/operator_profile.jpg';
---

<section class="py-12 md:py-24 bg-surface-container-low dark:bg-slate-950 border-b border-outline-variant dark:border-slate-800 transition-colors duration-300" id="profile">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    
    <!-- Title Column -->
    <div class="lg:col-span-4 relative pt-12 lg:pt-16">
      <!-- Absolute-positioned label sits above the grid alignment point -->
      <div class="absolute top-0 left-0 inline-flex items-center space-x-2 bg-primary/10 px-3 py-1 border border-primary/20">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        <span class="font-mono text-[10px] font-bold text-primary dark:text-primary-fixed uppercase tracking-widest">Operator_Profile</span>
      </div>

      <!-- Profile Image Module -->
      <div class="profile-module relative group max-w-[280px] cursor-pointer">
        <div class="hover-border absolute -inset-2 border border-primary/20 scale-95 opacity-0 group-hover:opacity-100 group-hover:scale-100 transition-all duration-500 pointer-events-none"></div>
        <div class="aspect-square bg-slate-200 dark:bg-slate-800 overflow-hidden border-2 border-on-background dark:border-slate-700 relative">
          <Image 
            src={operatorProfile} 
            alt="Operator Profile" 
            widths={[280, 560]}
            sizes="(max-width: 280px) 100vw, 280px"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
          />
          <!-- Scanline Overlay Effect - Now Fades Out on Hover -->
          <div class="scanline-overlay absolute inset-0 pointer-events-none opacity-40 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[length:100%_3px,4px_100%] group-hover:opacity-0 transition-opacity duration-500"></div>
        </div>
        <div class="absolute bottom-2 right-2 bg-primary text-white font-mono text-[10px] px-2 py-0.5 uppercase tracking-tighter">
          ID_CONFIRMED
        </div>
      </div>

      <div class="space-y-6 pt-10">
        <h2 class="font-mono font-extrabold text-3xl md:text-5xl text-on-background dark:text-slate-100 uppercase tracking-tighter leading-[0.9]">
          The <span class="text-primary">Bridge</span> Builder.
        </h2>
        <p class="font-mono text-xs text-on-surface-variant dark:text-slate-400 leading-relaxed italic">
          "Aligning advanced AI models with rigorous business requirements."
        </p>
      </div>
    </div>

    <!-- Content Column -->
    <div class="lg:col-span-8 space-y-12 pt-12 lg:pt-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Strategic Interface -->
        <div class="space-y-4">
          <h3 class="font-mono font-bold text-sm text-primary dark:text-primary-fixed uppercase tracking-wider underline decoration-2 underline-offset-4 transition-colors">Strategic_Interface</h3>
          <div class="font-mono text-sm text-on-surface-variant dark:text-slate-400 border-l-4 border-primary pl-6 py-1 transition-colors">
            <p class="leading-relaxed">
              Beyond technical implementation, I act as a strategic interface. My background uniquely combines a degree in Business Administration with rigorous technical workflow management. This allows me to align advanced AI models with actual business requirements, particularly within high-stakes domains such as the life sciences, pharmaceuticals, and ESG monitoring.
            </p>
          </div>
        </div>
        <!-- Data Integrity -->
        <div class="space-y-4">
          <h3 class="font-mono font-bold text-sm text-primary dark:text-primary-fixed uppercase tracking-wider underline decoration-2 underline-offset-4 transition-colors">Data_Integrity</h3>
          <div class="font-mono text-sm text-on-surface-variant dark:text-slate-400 border-l-4 border-primary pl-6 py-1 transition-colors">
            <p class="leading-relaxed">
              Years of handling massive, unstructured visual data pipelines taught me that a machine learning model is only as good as the signal it receives. My approach heavily prioritizes robust data validation, workflow standardization, and quality assurance, whether standardizing histopathological images or extracting urban footprints from raw satellite data.
            </p>
          </div>
        </div>
      </div>

      <!-- Technical Specification Paragraph (New) -->
      <div class="bg-on-background dark:bg-slate-900 p-8 border-l-8 border-secondary-container relative overflow-hidden transition-colors">
        <div class="absolute top-0 right-0 p-2 opacity-10 pointer-events-none">
          <span class="material-symbols-outlined text-6xl text-white">developer_board</span>
        </div>
        <div class="font-mono text-[10px] text-secondary-container font-bold mb-4 uppercase tracking-[0.2em] transition-colors">[ENGINEERING_SPEC]</div>
        <p class="font-mono text-xs md:text-sm text-slate-300 dark:text-slate-200 leading-relaxed relative z-10 transition-colors">
          My technical architecture is built on the intersection of classical imaging physics and modern deep learning. I specialize in building <span class="text-white font-bold">high-integrity Python pipelines</span> that bridge the gap between raw optical data (Multi-spectral Satellite GeoTIFFs, Whole Slide Images) and actionable AI. My core stack leverages <span class="text-secondary-container font-bold">PyTorch</span> for neural architectures and <span class="text-secondary-container font-bold">OpenCV</span> for signal processing, all underpinned by rigorous software craftsmanship: <span class="text-white font-bold">100% Type-safety (Mypy)</span>, <span class="text-white font-bold">Pydantic V2</span> validation, and <span class="text-white font-bold">Strategy-pattern</span> based modularity.
        </p>
      </div>

      <!-- Tech Stack / Metadata Strip -->
      <div class="bg-white dark:bg-slate-900 border border-outline-variant dark:border-slate-800 p-6 space-y-6 transition-colors">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div>
            <span class="block font-mono text-[10px] text-slate-500 uppercase font-bold mb-1">Human_Languages</span>
            <span class="font-mono text-xs text-on-background dark:text-slate-200">DE (Native), EN (Fluent), ES, PT</span>
          </div>
          <div>
            <span class="block font-mono text-[10px] text-slate-500 uppercase font-bold mb-1">Domain_Expertise</span>
            <span class="font-mono text-xs text-on-background dark:text-slate-200">Pharma, ESG, Media</span>
          </div>
          <div>
            <span class="block font-mono text-[10px] text-slate-500 uppercase font-bold mb-1">Core_Signal</span>
            <span class="font-mono text-xs text-on-background dark:text-slate-200">LAB/HSV, GANs, XAI</span>
          </div>
          <div>
            <span class="block font-mono text-[10px] text-slate-500 uppercase font-bold mb-1">Status</span>
            <span class="font-mono text-xs text-green-600 dark:text-green-400 font-bold uppercase">Ready_for_Deployment</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initProfileInteractivity() {
    const profileModule = document.querySelector('.profile-module');
    if (profileModule) {
      profileModule.addEventListener('click', () => {
        profileModule.classList.toggle('is-active');
      });
    }
  }

  // Initialize on page load
  initProfileInteractivity();
  // Re-initialize after Astro view transitions
  document.addEventListener('astro:after-swap', initProfileInteractivity);
</script>

<style>
  /* Mobile-specific active state for scanline/grayscale toggle */
  @media (max-width: 1023px) {
    .profile-module.is-active .scanline-overlay {
      opacity: 0 !important;
    }
    .profile-module.is-active img {
      filter: grayscale(0) !important;
    }
    .profile-module.is-active .hover-border {
      opacity: 100 !important;
      transform: scale(1) !important;
    }
  }
</style>
