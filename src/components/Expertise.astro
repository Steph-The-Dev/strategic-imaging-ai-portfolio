      <div class="space-y-1">
        <span class="font-mono text-[11px] md:text-xs text-primary dark:text-primary-fixed font-bold tracking-[0.3em] uppercase">Phase_Mapping</span>
        <h2 class="font-mono font-extrabold text-3xl md:text-4xl text-on-background dark:text-slate-100 uppercase tracking-tighter transition-colors">The Strategic Evolution</h2>
