<section class="py-12 md:py-24 bg-white dark:bg-slate-900 transition-colors duration-300" id="contact">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="border-2 border-on-surface dark:border-slate-700 p-6 sm:p-12 md:p-20 relative technical-grid transition-colors overflow-hidden">
      <div class="absolute top-4 left-4 font-mono text-[9px] text-outline dark:text-slate-500 font-bold uppercase tracking-widest">
        Request_Parameters
      </div>
      <div class="text-center space-y-10 relative z-10 py-4">
        <h2 class="font-mono font-extrabold text-2xl sm:text-4xl md:text-5xl text-on-background dark:text-slate-100 uppercase tracking-tighter leading-tight transition-colors break-words">
          Visual INTUITION.<br/>Algorithmic PRECISION.
        </h2>
        <div class="bg-surface-container dark:bg-slate-800 border border-outline-variant dark:border-slate-700 p-4 sm:p-6 max-w-xl mx-auto transition-colors w-full">
          <p class="font-mono text-xs sm:text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed transition-colors break-words">
            <span class="block mb-1">[AVAILABILITY]: Open for Data Science Opportunities</span>
            <span class="block mb-1">[ROLE_FOCUS]: Computer Vision / ML Engineer</span>
            <span class="block">[EDGE]: Deep Visual Domain Knowledge + AI Scalability</span>
          </p>
        </div>
        <div>
          <button 
            id="contact-trigger"
            class="inline-flex justify-center items-center px-6 sm:px-12 py-4 sm:py-5 bg-on-background dark:bg-slate-100 text-white dark:text-slate-900 font-mono text-xs sm:text-sm font-bold uppercase tracking-[0.2em] hover:bg-primary dark:hover:bg-primary-fixed focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 dark:focus:ring-offset-slate-900 transition-all group w-full sm:w-auto cursor-pointer"
          >
            INITIATE_DISCUSSION
            <span class="material-symbols-outlined ml-2 sm:ml-3 transition-transform group-hover:translate-x-1">arrow_forward_ios</span>
          </button>
        </div>
      </div>
      <div class="absolute bottom-4 right-4 font-mono text-[9px] text-outline dark:text-slate-500 font-bold uppercase">
        EOF_TRANSMISSION
      </div>
    </div>
  </div>
</section>

<script>
  function initContact() {
    const trigger = document.getElementById('contact-trigger');
    if (trigger) {
      trigger.addEventListener('click', () => {
        // Base64 for mail@stephthedev.de
        const encoded = "bWFpbEBzdGVwaHRoZWRldi5kZQ==";
        window.location.href = "mailto:" + atob(encoded);
      });
    }
  }

  initContact();
  document.addEventListener('astro:after-swap', initContact);
</script>
